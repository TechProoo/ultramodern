# Copy to .env.local for local overrides (git-ignored via *.local).
# Base URL of the backend API. No trailing slash.
# Local default (used when unset): http://localhost:3000
# In Netlify, set this in Site settings → Environment variables to your
# Railway backend URL, e.g. https://your-backend.up.railway.app
VITE_API_URL="http://localhost:3000"
